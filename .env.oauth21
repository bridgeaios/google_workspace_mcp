# =============================================================================
# Google Workspace MCP Server - OAuth 2.1 Configuration
# =============================================================================
# Copy this file to .env and update with your actual Google OAuth credentials
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Google OAuth 2.0 Client Credentials
# -----------------------------------------------------------------------------
# These credentials are obtained from Google Cloud Console after creating
# a Desktop Application OAuth 2.0 client.
#
# To obtain:
# 1. Go to https://console.cloud.google.com/
# 2. Create/select a project
# 3. Navigate to APIs & Services → Credentials
# 4. Click "Create Credentials" → "OAuth client ID"
# 5. Select "Desktop Application" as the application type
# 6. Download the JSON and extract client_id and client_secret
#
GOOGLE_OAUTH_CLIENT_ID="YOUR_CLIENT_ID_HERE"
GOOGLE_OAUTH_CLIENT_SECRET="YOUR_CLIENT_SECRET_HERE"

# -----------------------------------------------------------------------------
# DEVELOPMENT SETTINGS
# -----------------------------------------------------------------------------
# WARNING: Only enable insecure transport for local development!
# OAuth 2.1 requires HTTPS in production. Setting this to true allows HTTP
# redirect URIs for localhost testing.
#
OAUTH2_ALLOW_INSECURE_TRANSPORT=true

# Enable debug logging for OAuth flows (development only)
OAUTH2_ENABLE_DEBUG=false

# -----------------------------------------------------------------------------
# OAUTH 2.1 MODE CONFIGURATION
# -----------------------------------------------------------------------------
# Enable OAuth 2.1 for multi-user bearer token authentication
# This is REQUIRED for multi-user scenarios and external OAuth providers
#
MCP_ENABLE_OAUTH21=true

# External OAuth Provider Mode
# When enabled, the server expects external systems to handle OAuth flow
# and provide valid bearer tokens in Authorization headers
# EXTERNAL_OAUTH21_PROVIDER=false

# Stateless Mode (container-friendly)
# When enabled, no credentials are written to disk - all tokens stored in memory
# Requires MCP_ENABLE_OAUTH21=true
# WORKSPACE_MCP_STATELESS_MODE=false

# -----------------------------------------------------------------------------
# LEGACY COMPATIBILITY
# -----------------------------------------------------------------------------
# Enable legacy OAuth 2.0 authentication alongside OAuth 2.1
# Recommended during migration or for single-user scenarios
#
OAUTH2_ENABLE_LEGACY_AUTH=true

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
# Base server URI (without port)
# WORKSPACE_MCP_BASE_URI=http://localhost

# Server port (default: 8000)
# WORKSPACE_MCP_PORT=8000

# Server bind host (0.0.0.0 for all interfaces, 127.0.0.1 for localhost only)
# WORKSPACE_MCP_HOST=0.0.0.0

# External URL for reverse proxy setups
# WORKSPACE_EXTERNAL_URL=https://your-domain.com

# OAuth redirect URI override (auto-constructed if not set)
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/oauth2callback

# -----------------------------------------------------------------------------
# FASTMCP OAUTH PROXY STORAGE BACKEND (OAuth 2.1)
# -----------------------------------------------------------------------------
# Storage backend for OAuth proxy state. Options: memory, disk, valkey
# Default: disk on Mac/Windows, memory on Linux
#
# WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=memory

# -----------------------------------------------------------------------------
# Storage Backend: Memory (default on Linux)
# -----------------------------------------------------------------------------
# - Fast, no persistence, data lost on restart
# - Best for: development, testing, stateless deployments
#
WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=memory

# -----------------------------------------------------------------------------
# Storage Backend: Disk (default on Mac/Windows)
# -----------------------------------------------------------------------------
# - Persists across restarts, single-server only
# - Best for: single-server production, persistent caching
#
# WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=disk
# WORKSPACE_MCP_OAUTH_PROXY_DISK_DIRECTORY=~/.fastmcp/oauth-proxy

# -----------------------------------------------------------------------------
# Storage Backend: Valkey/Redis
# -----------------------------------------------------------------------------
# - Distributed, multi-server support
# - Best for: production, multi-server deployments, cloud native
#
# WORKSPACE_MCP_OAUTH_PROXY_STORAGE_BACKEND=valkey
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_HOST=localhost
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_PORT=6379
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_USE_TLS=false
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_DB=0
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_USERNAME=
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_PASSWORD=
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_REQUEST_TIMEOUT_MS=5000
# WORKSPACE_MCP_OAUTH_PROXY_VALKEY_CONNECTION_TIMEOUT_MS=10000

# -----------------------------------------------------------------------------
# ENCRYPTION NOTES
# -----------------------------------------------------------------------------
# - Disk and Valkey storage are encrypted with Fernet
# - Key derived from FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY if set,
#   otherwise from GOOGLE_OAUTH_CLIENT_SECRET
# - For stable decryption across client-secret rotations, set
#   FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY explicitly
#
# FASTMCP_SERVER_AUTH_GOOGLE_JWT_SIGNING_KEY=your-secret-signing-key

# -----------------------------------------------------------------------------
# OPTIONAL: Google Custom Search Configuration
# -----------------------------------------------------------------------------
# Required only if using the search_custom tool
# Get API key: https://developers.google.com/custom-search/v1/overview
# Create search engine: https://programmablesearchengine.google.com/
#
# GOOGLE_PSE_API_KEY=your-api-key
# GOOGLE_PSE_ENGINE_ID=your-engine-id

# -----------------------------------------------------------------------------
# OPTIONAL: Default User Email (Single-User Mode)
# -----------------------------------------------------------------------------
# Set this to skip email prompt in single-user mode
# Note: Cannot be used with MCP_ENABLE_OAUTH21=true
#
# USER_GOOGLE_EMAIL=your.email@gmail.com

# -----------------------------------------------------------------------------
# OPTIONAL: Attachment Storage
# -----------------------------------------------------------------------------
# Directory for downloaded attachments (default: ~/.workspace-mcp/attachments/)
# WORKSPACE_ATTACHMENT_DIR=/path/to/attachments

# -----------------------------------------------------------------------------
# OPTIONAL: File Access Control
# -----------------------------------------------------------------------------
# Colon-separated list of allowed directories for local file reads
# (semicolon-separated on Windows)
# ALLOWED_FILE_DIRS=/home/user/documents:/data/shared
